# Copy values into inventory.ini [media:vars] — Ansible templates these into .env on the server

# Server
server_domain=media.example.com
admin_email=admin@example.com
server_name=media-server
frontend_title=My Media Server
timezone=Europe/London

# Secrets
qbittorrent_password=change-me
jellyfin_password=change-me
seerr_admin_password=change-me

# Optional — auto-generated into .credentials/ next to your inventory if omitted
# prowlarr_api_key=
# radarr_api_key=
# sonarr_api_key=

# jellyfin_api_key is auto-generated on first deploy (scripts/init-services.sh)
