# Generated by Ansible — do not edit on the server; change inventory.ini and re-run playbook
PUID={{ ansible_facts.user_uid }}
PGID={{ ansible_facts.user_gid }}
TZ={{ timezone }}

BIND_HOST={{ bind_host }}
CONTENT_DIR={{ content_dir }}

# VPN Configuration (for qBittorrent Gluetun routing)
VPN_ENABLED={{ vpn_enabled | default(false) | bool }}
VPN_SERVICE_PROVIDER={{ vpn_provider | default('custom') }}
VPN_TYPE={{ vpn_type | default('wireguard') }}
OPENVPN_USER={{ vpn_username | default('') }}
OPENVPN_PASSWORD={{ vpn_password | default('') }}
WIREGUARD_PRIVATE_KEY={{ vpn_wireguard_private_key | default('') }}
WIREGUARD_ADDRESSES={{ vpn_wireguard_addresses | default('') }}
# Required for vpn_provider=custom + vpn_type=wireguard — named providers
# (e.g. nordvpn) auto-resolve these instead, so they can be left blank.
WIREGUARD_ENDPOINT_IP={{ vpn_wireguard_endpoint_ip | default('') }}
WIREGUARD_ENDPOINT_PORT={{ vpn_wireguard_endpoint_port | default('') }}
WIREGUARD_PUBLIC_KEY={{ vpn_wireguard_public_key | default('') }}
WIREGUARD_PRESHARED_KEY={{ vpn_wireguard_preshared_key | default('') }}
VPN_SERVER_COUNTRIES={{ vpn_server_countries | default('') }}

SERVER_DOMAIN={{ server_domain }}
ADMIN_EMAIL={{ admin_email }}

QBITTORRENT_PORT={{ qbittorrent_port }}
PROWLARR_PORT={{ prowlarr_port }}
RADARR_PORT={{ radarr_port }}
SONARR_PORT={{ sonarr_port }}
BAZARR_PORT={{ bazarr_port }}
SEERR_PORT={{ seerr_port }}
JELLYFIN_PORT={{ jellyfin_port }}

QBITTORRENT_PASSWORD={{ qbittorrent_password }}
RADARR_API_KEY={{ radarr_api_key }}
SONARR_API_KEY={{ sonarr_api_key }}
PROWLARR_API_KEY={{ prowlarr_api_key }}

JELLYFIN_USERNAME={{ jellyfin_username }}
JELLYFIN_PASSWORD={{ jellyfin_password }}
JELLYFIN_SERVER_NAME={{ jellyfin_server_name }}

# Populated automatically by scripts/init-services.sh after Jellyfin setup
JELLYFIN_API_KEY={{ lookup('ansible.builtin.ini', 'JELLYFIN_API_KEY type=properties file=' ~ root_dir ~ '/.env', errors='ignore') | default('') }}

# Populated automatically by scripts/init-services.sh — read back from the
# config.yaml Bazarr generates on first boot (like JELLYFIN_API_KEY above)
BAZARR_API_KEY={{ lookup('ansible.builtin.ini', 'BAZARR_API_KEY type=properties file=' ~ root_dir ~ '/.env', errors='ignore') | default('') }}
