{% macro dotenv(value) -%}'{{ (value | default('') | string) | replace("\\", "\\\\") | replace("'", "\\'") }}'{%- endmacro %}
# Generated by Ansible — do not edit on the server; change inventory.ini and re-run playbook
PUID={{ ansible_facts.user_uid }}
PGID={{ ansible_facts.user_gid }}
TZ={{ dotenv(timezone) }}

BIND_HOST={{ dotenv(bind_host) }}
CONTENT_DIR={{ dotenv(content_dir) }}

# VPN Configuration (for qBittorrent Gluetun routing)
VPN_ENABLED={{ vpn_enabled | default(false) | bool }}
VPN_SERVICE_PROVIDER={{ dotenv(vpn_provider | default('custom')) }}
VPN_TYPE={{ dotenv(vpn_type | default('wireguard')) }}
WIREGUARD_ADDRESSES={{ dotenv(vpn_wireguard_addresses | default('')) }}
# Required for vpn_provider=custom + vpn_type=wireguard — named providers
# (e.g. nordvpn) auto-resolve these instead, so they can be left blank.
WIREGUARD_ENDPOINT_IP={{ dotenv(vpn_wireguard_endpoint_ip | default('')) }}
WIREGUARD_ENDPOINT_PORT={{ dotenv(vpn_wireguard_endpoint_port | default('')) }}
WIREGUARD_PUBLIC_KEY={{ dotenv(vpn_wireguard_public_key | default('')) }}
VPN_SERVER_COUNTRIES={{ dotenv(vpn_server_countries | default('')) }}
GLUETUN_HEALTH_TARGET_ADDRESSES={{ dotenv(gluetun_health_target_addresses) }}

SERVER_DOMAIN={{ dotenv(server_domain) }}
ADMIN_EMAIL={{ dotenv(admin_email) }}

QBITTORRENT_PORT={{ qbittorrent_port }}
QBITTORRENT_PEER_PORT={{ qbittorrent_peer_port }}
QBITTORRENT_PEER_BIND_HOST={{ dotenv(qbittorrent_peer_bind_host) }}
PROWLARR_PORT={{ prowlarr_port }}
RADARR_PORT={{ radarr_port }}
SONARR_PORT={{ sonarr_port }}
BAZARR_PORT={{ bazarr_port }}
SEERR_PORT={{ seerr_port }}
JELLYFIN_PORT={{ jellyfin_port }}

QBITTORRENT_PASSWORD={{ dotenv(qbittorrent_password) }}
RADARR_API_KEY={{ dotenv(radarr_api_key) }}
SONARR_API_KEY={{ dotenv(sonarr_api_key) }}
PROWLARR_API_KEY={{ dotenv(prowlarr_api_key) }}

JELLYFIN_USERNAME={{ dotenv(jellyfin_username) }}
JELLYFIN_PASSWORD={{ dotenv(jellyfin_password) }}
JELLYFIN_SERVER_NAME={{ dotenv(jellyfin_server_name) }}

# Populated automatically by scripts/init-services.sh after Jellyfin setup
JELLYFIN_API_KEY={{ dotenv(jellyfin_api_key | default('')) }}

# Populated automatically by scripts/init-services.sh — read back from the
# config.yaml Bazarr generates on first boot (like JELLYFIN_API_KEY above)
BAZARR_API_KEY={{ dotenv(bazarr_api_key | default('')) }}
