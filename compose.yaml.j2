services:
  traefik:
    image: traefik:{{ traefik_version }}
    container_name: traefik
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - ./config/traefik/letsencrypt:/letsencrypt
      - ./config/traefik/traefik.yml:/etc/traefik/traefik.yml:ro
    networks:
      - {{ public_network }}
    healthcheck:
      test: ["CMD", "traefik", "healthcheck", "--ping"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s

{% if vpn_enabled | default(false) | bool %}
  gluetun:
    image: qmcgaw/gluetun:{{ gluetun_version }}
    container_name: gluetun
    cap_add:
      - NET_ADMIN
    devices:
      - /dev/net/tun:/dev/net/tun
    ports:
      - "${BIND_HOST}:${QBITTORRENT_PORT}:8080"
      - "6881:6881/tcp"
      - "6881:6881/udp"
    environment:
      - VPN_SERVICE_PROVIDER=${VPN_SERVICE_PROVIDER}
      - VPN_TYPE=${VPN_TYPE}
      - OPENVPN_USER=${OPENVPN_USER}
      - OPENVPN_PASSWORD=${OPENVPN_PASSWORD}
      - WIREGUARD_PRIVATE_KEY=${WIREGUARD_PRIVATE_KEY}
      - WIREGUARD_ADDRESSES=${WIREGUARD_ADDRESSES}
      - WIREGUARD_ENDPOINT_IP=${WIREGUARD_ENDPOINT_IP}
      - WIREGUARD_ENDPOINT_PORT=${WIREGUARD_ENDPOINT_PORT}
      - WIREGUARD_PUBLIC_KEY=${WIREGUARD_PUBLIC_KEY}
      - WIREGUARD_PRESHARED_KEY=${WIREGUARD_PRESHARED_KEY}
      - SERVER_COUNTRIES=${VPN_SERVER_COUNTRIES}
      - TZ=${TZ}
    volumes:
      - ./gluetun:/gluetun
    networks:
      {{ internal_network }}:
        aliases:
          - qbittorrent
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "ping -c 1 1.1.1.1 || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 10s
{% endif %}

  qbittorrent:
    image: linuxserver/qbittorrent:{{ qbittorrent_version }}
    container_name: qbittorrent
    restart: unless-stopped
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
      - WEBUI_PORT=8080
    volumes:
      - ./torrent/config:/config
      - ${CONTENT_DIR}/torrents:/data/torrents
{% if vpn_enabled | default(false) | bool %}
    network_mode: "service:gluetun"
    depends_on:
      gluetun:
        condition: service_healthy
{% else %}
    ports:
      - "6881:6881/tcp"
      - "6881:6881/udp"
      - "${BIND_HOST}:${QBITTORRENT_PORT}:8080"
    networks:
      - {{ internal_network }}
{% endif %}
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://127.0.0.1:8080/ || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s

  prowlarr:
    image: linuxserver/prowlarr:{{ prowlarr_version }}
    container_name: prowlarr
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
    volumes:
      - ./media-management/prowlarr:/config
    ports:
      - "${BIND_HOST}:${PROWLARR_PORT}:9696"
    restart: unless-stopped
    networks:
      - {{ internal_network }}
    depends_on:
      qbittorrent:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://127.0.0.1:9696/ping || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 90s

  radarr:
    image: linuxserver/radarr:{{ radarr_version }}
    container_name: radarr
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
    volumes:
      - ./media-management/radarr:/config
      - ${CONTENT_DIR}:/data
    ports:
      - "${BIND_HOST}:${RADARR_PORT}:7878"
    restart: unless-stopped
    networks:
      - {{ internal_network }}
    depends_on:
      qbittorrent:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://127.0.0.1:7878/ping || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 90s

  sonarr:
    image: linuxserver/sonarr:{{ sonarr_version }}
    container_name: sonarr
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
    volumes:
      - ./media-management/sonarr:/config
      - ${CONTENT_DIR}:/data
    ports:
      - "${BIND_HOST}:${SONARR_PORT}:8989"
    restart: unless-stopped
    networks:
      - {{ internal_network }}
    depends_on:
      qbittorrent:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://127.0.0.1:8989/ping || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 90s

  bazarr:
    image: linuxserver/bazarr:{{ bazarr_version }}
    container_name: bazarr
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
    volumes:
      - ./media-management/bazarr:/config
      - ${CONTENT_DIR}:/data
    ports:
      - "${BIND_HOST}:${BAZARR_PORT}:6767"
    restart: unless-stopped
    networks:
      - {{ internal_network }}
    depends_on:
      radarr:
        condition: service_healthy
      sonarr:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "wget --no-verbose --tries=1 --spider http://127.0.0.1:6767/ || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 90s

  jellyfin:
    image: linuxserver/jellyfin:{{ jellyfin_version }}
    container_name: jellyfin
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
      - JELLYFIN_PublishedServerUrl=https://jellyfin.${SERVER_DOMAIN}
    volumes:
      - ./jellyfin:/config
      - ${CONTENT_DIR}/media:/data/media
    ports:
      - "${BIND_HOST}:${JELLYFIN_PORT}:8096"
    restart: unless-stopped
    networks:
      - {{ internal_network }}
      - {{ public_network }}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.jellyfin.rule=Host(`jellyfin.${SERVER_DOMAIN}`)"
      - "traefik.http.routers.jellyfin.entrypoints=websecure"
      - "traefik.http.routers.jellyfin.tls.certresolver=myresolver"
      - "traefik.http.services.jellyfin.loadbalancer.server.port=8096"
      - "traefik.http.services.jellyfin.loadbalancer.responseForwarding.flushInterval=100ms"
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://127.0.0.1:8096/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 120s

  seerr:
    image: ghcr.io/seerr-team/seerr:{{ seerr_version }}
    init: true
    container_name: seerr
    environment:
      - LOG_LEVEL=info
      - TZ=${TZ}
      - PORT=5055
    volumes:
      - ./seerr:/app/config
    ports:
      - "${BIND_HOST}:${SEERR_PORT}:5055"
    restart: unless-stopped
    networks:
      - {{ internal_network }}
      - {{ public_network }}
    depends_on:
      jellyfin:
        condition: service_healthy
      radarr:
        condition: service_healthy
      sonarr:
        condition: service_healthy
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.seerr.rule=Host(`${SERVER_DOMAIN}`)"
      - "traefik.http.routers.seerr.entrypoints=websecure"
      - "traefik.http.routers.seerr.tls.certresolver=myresolver"
      - "traefik.http.services.seerr.loadbalancer.server.port=5055"
    healthcheck:
      test: ["CMD-SHELL", "wget --no-verbose --tries=1 --spider http://127.0.0.1:5055/api/v1/status || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s

networks:
  {{ internal_network }}:
    name: {{ internal_network }}
    driver: bridge
  {{ public_network }}:
    name: {{ public_network }}
    driver: bridge
