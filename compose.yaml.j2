services:
  traefik:
    image: traefik:{{ traefik_version }}
    container_name: traefik
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - ./config/traefik/letsencrypt:/letsencrypt
      - ./config/traefik/traefik.yml:/etc/traefik/traefik.yml:ro
    networks:
      - {{ public_network }}
    healthcheck:
      test: ["CMD", "traefik", "healthcheck", "--ping"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s

  qbittorrent:
    image: linuxserver/qbittorrent:{{ qbittorrent_version }}
    container_name: qbittorrent
    restart: unless-stopped
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
      - WEBUI_PORT=8080
    volumes:
      - ./torrent/config:/config
      - ./content/torrents:/data/torrents
    ports:
      - "6881:6881/tcp"
      - "6881:6881/udp"
      - "127.0.0.1:${QBITTORRENT_PORT}:8080"
    networks:
      - {{ internal_network }}
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://127.0.0.1:8080/ || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s

  prowlarr:
    image: linuxserver/prowlarr:{{ prowlarr_version }}
    container_name: prowlarr
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
    volumes:
      - ./media-management/prowlarr:/config
    ports:
      - "127.0.0.1:${PROWLARR_PORT}:9696"
    restart: unless-stopped
    networks:
      - {{ internal_network }}
    depends_on:
      qbittorrent:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://127.0.0.1:9696/ping || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 90s

  radarr:
    image: linuxserver/radarr:{{ radarr_version }}
    container_name: radarr
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
    volumes:
      - ./media-management/radarr:/config
      - ./content:/data
    ports:
      - "127.0.0.1:${RADARR_PORT}:7878"
    restart: unless-stopped
    networks:
      - {{ internal_network }}
    depends_on:
      qbittorrent:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://127.0.0.1:7878/ping || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 90s

  sonarr:
    image: linuxserver/sonarr:{{ sonarr_version }}
    container_name: sonarr
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
    volumes:
      - ./media-management/sonarr:/config
      - ./content:/data
    ports:
      - "127.0.0.1:${SONARR_PORT}:8989"
    restart: unless-stopped
    networks:
      - {{ internal_network }}
    depends_on:
      qbittorrent:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://127.0.0.1:8989/ping || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 90s

  bazarr:
    image: linuxserver/bazarr:{{ bazarr_version }}
    container_name: bazarr
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
    volumes:
      - ./media-management/bazarr:/config
      - ./content:/data
    ports:
      - "127.0.0.1:${BAZARR_PORT}:6767"
    restart: unless-stopped
    networks:
      - {{ internal_network }}
    depends_on:
      radarr:
        condition: service_healthy
      sonarr:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "wget --no-verbose --tries=1 --spider http://127.0.0.1:6767/ || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 90s

  jellyfin:
    image: linuxserver/jellyfin:{{ jellyfin_version }}
    container_name: jellyfin
    environment:
      - PUID=${PUID}
      - PGID=${PGID}
      - TZ=${TZ}
      - JELLYFIN_PublishedServerUrl=https://jellyfin.${SERVER_DOMAIN}
    volumes:
      - ./jellyfin:/config
      - ./content/media:/data/media
    ports:
      - "127.0.0.1:${JELLYFIN_PORT}:8096"
    restart: unless-stopped
    networks:
      - {{ internal_network }}
      - {{ public_network }}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.jellyfin.rule=Host(`jellyfin.${SERVER_DOMAIN}`)"
      - "traefik.http.routers.jellyfin.entrypoints=websecure"
      - "traefik.http.routers.jellyfin.tls.certresolver=myresolver"
      - "traefik.http.services.jellyfin.loadbalancer.server.port=8096"
      - "traefik.http.services.jellyfin.loadbalancer.responseForwarding.flushInterval=100ms"
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://127.0.0.1:8096/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 120s

  seerr:
    image: ghcr.io/seerr-team/seerr:{{ seerr_version }}
    init: true
    container_name: seerr
    environment:
      - LOG_LEVEL=info
      - TZ=${TZ}
      - PORT=5055
    volumes:
      - ./seerr:/app/config
    ports:
      - "127.0.0.1:${SEERR_PORT}:5055"
    restart: unless-stopped
    networks:
      - {{ internal_network }}
      - {{ public_network }}
    depends_on:
      jellyfin:
        condition: service_healthy
      radarr:
        condition: service_healthy
      sonarr:
        condition: service_healthy
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.seerr.rule=Host(`${SERVER_DOMAIN}`)"
      - "traefik.http.routers.seerr.entrypoints=websecure"
      - "traefik.http.routers.seerr.tls.certresolver=myresolver"
      - "traefik.http.services.seerr.loadbalancer.server.port=5055"
    healthcheck:
      test: ["CMD-SHELL", "wget --no-verbose --tries=1 --spider http://127.0.0.1:5055/api/v1/status || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s

networks:
  {{ internal_network }}:
    name: {{ internal_network }}
    driver: bridge
  {{ public_network }}:
    name: {{ public_network }}
    driver: bridge
